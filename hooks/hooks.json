{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Glob|WebFetch",
        "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pretooluse.js\"", "timeout": 20 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/posttooluse.js\"", "timeout": 20 }]
      }
    ]
  }
}
